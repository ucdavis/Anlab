@model AnlabMvc.Models.Email.MjmlEmailTemplateModelBase

@if (Model?.BypassClientEmail == true)
{
  <mj-table cellpadding="0"
            cellspacing="0"
            width="100%"
            color="#172033"
            font-size="16px"
            line-height="1.55"
            padding="0px 0px 24px 0px">
    <tr>
      <td style="background-color:#def0fc;border:1px solid #b7d7ee;border-radius:8px;padding:16px 24px;">
        <div style="font-weight:700;line-height:1.4;padding:0 0 8px 0;">Email not sent to clients.</div>
        @if (!string.IsNullOrWhiteSpace(Model.BypassRecipientList))
        {
          <div><strong>Intended recipient(s):</strong><br />@Model.BypassRecipientList</div>
        }
      </td>
    </tr>
  </mj-table>
}
