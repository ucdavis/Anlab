@using System
@using System.Linq
@using Anlab.Core.Models
@model Anlab.Core.Domain.Order

@{
    var order = Model?.GetOrderDetails() ?? new OrderDetails();
    var selectedTests = order.SelectedTests ?? Array.Empty<TestDetails>();
    var savedTests = string.IsNullOrWhiteSpace(Model?.SavedTestDetails)
        ? Array.Empty<TestItemModel>()
        : Model.GetTestDetails() ?? Array.Empty<TestItemModel>();
    var processingFee = string.Equals(order.Payment?.ClientType, "uc", StringComparison.OrdinalIgnoreCase)
        ? order.InternalProcessingFee
        : order.ExternalProcessingFee;
}

<mj-text font-size="22px"
         font-weight="700"
         line-height="1.3"
         padding="0px 0px 12px 0px">
  Order Details (@order.Quantity Samples)
</mj-text>
<mj-table cellpadding="0"
          cellspacing="0"
          width="100%"
          color="#172033"
          font-size="14px"
          line-height="1.45"
          padding="0px 0px 24px 0px">
  <tr>
    <th align="left" width="46%" style="border-bottom:1px solid #d9e1ea;padding:0 10px 10px 0;font-weight:700;">Test(s)</th>
    <th align="right" width="18%" style="border-bottom:1px solid #d9e1ea;padding:0 10px 10px 0;font-weight:700;">Per Test</th>
    <th align="right" width="18%" style="border-bottom:1px solid #d9e1ea;padding:0 10px 10px 0;font-weight:700;">Setup</th>
    <th align="right" width="18%" style="border-bottom:1px solid #d9e1ea;padding:0 0 10px 0;font-weight:700;">Test Total</th>
  </tr>
  @foreach (var test in selectedTests)
  {
      var savedTest = savedTests.FirstOrDefault(a => a.Id == test.Id);
      if (savedTest?.Public != true && savedTest?.Reporting != true)
      {
          continue;
      }

      <tr>
        <td width="46%" style="border-bottom:1px solid #edf1f5;padding:10px 10px 10px 0;">@test.Analysis</td>
        <td align="right" width="18%" style="border-bottom:1px solid #edf1f5;padding:10px 10px 10px 0;white-space:nowrap;">@test.Cost.ToString("C")</td>
        <td align="right" width="18%" style="border-bottom:1px solid #edf1f5;padding:10px 10px 10px 0;white-space:nowrap;">@test.SetupCost.ToString("C")</td>
        <td align="right" width="18%" style="border-bottom:1px solid #edf1f5;padding:10px 0 10px 0;white-space:nowrap;">@test.Total.ToString("C")</td>
      </tr>
  }
  <tr>
    <td style="padding:12px 10px 0 0;"></td>
    <td colspan="2" align="left" style="padding:12px 10px 0 0;font-weight:700;">Processing Fee</td>
    <td align="right" style="padding:12px 0 0 0;white-space:nowrap;">@processingFee.ToString("C")</td>
  </tr>
  <tr>
    <td style="padding:8px 10px 0 0;"></td>
    <td colspan="2" align="left" style="padding:8px 10px 0 0;font-weight:700;">Grand Total</td>
    <td align="right" style="padding:8px 0 0 0;font-weight:700;white-space:nowrap;">@order.GrandTotal.ToString("C")</td>
  </tr>
</mj-table>
