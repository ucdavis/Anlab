@using Anlab.Core.Models
@model AnlabMvc.Models.Email.WorkRequests.WorkRequestFinalizedEmailModel

@{
    Layout = "/Views/Emails/Shared/_MjmlEmailLayout.cshtml";
    var orderDetails = Model.Order?.GetOrderDetails() ?? new OrderDetails();
    var requestNumber = string.IsNullOrWhiteSpace(Model.Order?.RequestNum) ? "-" : Model.Order.RequestNum;
    var project = string.IsNullOrWhiteSpace(orderDetails.Project) ? "-" : orderDetails.Project;
    var isInternalClient = orderDetails.Payment?.IsInternalClient == true;
    var resultsMessage = isInternalClient
        ? "Your work order has been completed and your results are now available."
        : "Your work order has been completed and your results are now available. You are required to pay at this time.";
    var defaultButtonText = isInternalClient ? "Get Your Results" : "Get Your Results and Pay";
    var buttonText = string.IsNullOrWhiteSpace(Model.ButtonText) ? defaultButtonText : Model.ButtonText;
    var dispositionText = string.Empty;

    switch ((orderDetails.LabworksSampleDisposition ?? string.Empty).Trim().ToUpperInvariant())
    {
        case "S":
            dispositionText = "I will pick up samples not later than 30 days from report date.";
            break;
        case "D":
        case "A":
            dispositionText = "Dispose of samples 30 days from report date.";
            break;
        case "R":
            dispositionText = "Return samples at client cost.";
            break;
        case "H":
            dispositionText = "Samples are being held.";
            break;
        default:
            dispositionText = "Please enquire about your sample disposition.";
            break;
    }
}

<mj-text mj-class="heading-primary">
  Work Request Finalized
</mj-text>
<mj-text mj-class="heading-secondary">
  Work Request @requestNumber
</mj-text>
<mj-text mj-class="body-copy">
  Results for Project @project
</mj-text>

<mj-table cellpadding="0"
          cellspacing="0"
          width="100%"
          mj-class="content-table">
  <tr>
    <td style="background-color:#def0fc;border:1px solid #b7d7ee;border-radius:8px;padding:16px 24px;">
      @resultsMessage
    </td>
  </tr>
</mj-table>

@if (!string.IsNullOrWhiteSpace(Model.ButtonUrl))
{
    @await Html.PartialAsync("/Views/Emails/Shared/_MjmlEmailButton.cshtml", new AnlabMvc.Models.Email.MjmlEmailButtonModel(buttonText, Model.ButtonUrl))
}

@if (!string.IsNullOrWhiteSpace(dispositionText))
{
    <mj-table cellpadding="0"
              cellspacing="0"
              width="100%"
              mj-class="compact-content-table">
      <tr>
        <td style="background-color:#f4f6f8;border:1px solid #d9e1ea;border-radius:8px;padding:18px 24px;">
          <div style="font-weight:700;line-height:1.4;padding:0 0 8px 0;">Sample Disposition</div>
          <div>@dispositionText</div>
        </td>
      </tr>
    </mj-table>
}
